generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SALES_MANAGER
  SDR
  AE
  READ_ONLY
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  DISQUALIFIED
  MQL
  SQL
  OPPORTUNITY
  CONVERTED
  ARCHIVED
}

enum LeadSource {
  WEBSITE_FORM
  LANDING_PAGE
  CHAT_WIDGET
  LINKEDIN_IMPORT
  CSV_UPLOAD
  API_INGESTION
  AD_PLATFORM
  MANUAL
  REFERRAL
}

enum OpportunityStage {
  PROSPECTING
  QUALIFICATION
  NEED_ANALYSIS
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  TASK
  SMS
  LINKEDIN_MESSAGE
  SYSTEM
}

enum SequenceStepType {
  EMAIL
  LINKEDIN
  SMS
  WAIT
  CONDITION
}

enum WorkflowTriggerType {
  LEAD_CREATED
  LEAD_UPDATED
  LEAD_STAGE_CHANGED
  LEAD_SCORE_CHANGED
  OPPORTUNITY_CREATED
  OPPORTUNITY_STAGE_CHANGED
  TASK_COMPLETED
  EMAIL_OPENED
  EMAIL_CLICKED
  FORM_SUBMITTED
  SCHEDULED
}

enum WorkflowActionType {
  SEND_EMAIL
  CREATE_TASK
  UPDATE_LEAD
  UPDATE_LEAD_SCORE
  ASSIGN_OWNER
  SEND_SLACK_NOTIFICATION
  SEND_WEBHOOK
  ADD_TO_SEQUENCE
  CREATE_OPPORTUNITY
  SEND_SMS
  TAG_LEAD
}

enum NotificationChannel {
  EMAIL
  SLACK
  IN_APP
  SMS
}

enum IntegrationProvider {
  SALESFORCE
  HUBSPOT
  ZOHO
  SLACK
  MICROSOFT_TEAMS
  GMAIL
  OUTLOOK
  LINKEDIN
  META
  GOOGLE_ADS
  CLEARBIT
  APOLLO
  ZOOMINFO
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          UserRole   @default(SDR)
  avatarUrl     String?
  phone         String?
  title         String?
  isActive      Boolean    @default(true)
  emailVerified Boolean    @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  assignedLeads      Lead[]         @relation("LeadOwner")
  createdLeads       Lead[]         @relation("LeadCreator")
  assignedOpportunities Opportunity[] @relation("OpportunityOwner")
  activities         Activity[]
  tasks              Task[]
  notifications      Notification[]
  sequences          Sequence[]
  loginHistory       LoginHistory[]

  @@map("users")
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  ipAddress String?
  userAgent String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_history")
}

model Lead {
  id            String      @id @default(uuid())
  firstName     String
  lastName      String
  email         String?
  phone         String?
  jobTitle      String?
  linkedinUrl   String?
  companyId     String?
  score         Int         @default(0)
  aiScore       Float       @default(0)
  status        LeadStatus  @default(NEW)
  source        LeadSource  @default(MANUAL)
  sourceUrl     String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmTerm       String?
  utmContent    String?
  notes         String?
  customFields  Json?
  timezone      String?
  ownerId       String?
  createdById   String?
  lastContactedAt DateTime?
  convertedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  company       Company?        @relation(fields: [companyId], references: [id])
  owner         User?           @relation("LeadOwner", fields: [ownerId], references: [id])
  createdBy     User?           @relation("LeadCreator", fields: [createdById], references: [id])
  contacts      Contact[]
  activities    Activity[]
  tasks         Task[]
  opportunities Opportunity[]
  leadScores    LeadScore[]
  chatbotSessions ChatbotSession[]

  @@index([email])
  @@index([status])
  @@index([score])
  @@index([ownerId])
  @@index([companyId])
  @@map("leads")
}

model Company {
  id            String   @id @default(uuid())
  name          String
  domain        String?
  industry      String?
  employeeCount Int?
  revenue       String?
  description   String?
  logoUrl       String?
  linkedinUrl   String?
  city          String?
  state         String?
  country       String?
  phone         String?
  technologies  Json?
  foundedYear   Int?
  isPublic      Boolean?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leads       Lead[]
  opportunities Opportunity[]

  @@index([domain])
  @@index([industry])
  @@map("companies")
}

model Contact {
  id          String   @id @default(uuid())
  leadId      String
  firstName   String
  lastName    String
  email       String?
  phone       String?
  jobTitle    String?
  linkedinUrl String?
  role        String?
  isPrimary   Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("contacts")
}

model Activity {
  id          String       @id @default(uuid())
  leadId      String
  userId      String?
  type        ActivityType
  subject     String?
  description String?
  metadata    Json?
  duration    Int?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@index([userId])
  @@index([type])
  @@map("activities")
}

model Task {
  id          String     @id @default(uuid())
  leadId      String?
  userId      String
  title       String
  description String?
  status      String     @default("pending")
  priority    String     @default("medium")
  dueDate     DateTime?
  completedAt DateTime?
  metadata    Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  lead        Lead?      @relation(fields: [leadId], references: [id])
  user        User       @relation(fields: [userId], references: [id])
  aiGenerated Boolean    @default(false)

  @@index([userId])
  @@index([leadId])
  @@index([status])
  @@map("tasks")
}

model Opportunity {
  id          String            @id @default(uuid())
  leadId      String
  companyId   String?
  ownerId     String?
  name        String
  stage       OpportunityStage  @default(PROSPECTING)
  value       Decimal           @default(0)
  currency    String            @default("USD")
  probability Int               @default(10)
  forecastDate DateTime?
  closeDate   DateTime?
  notes       String?
  lossReason  String?
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  lead        Lead              @relation(fields: [leadId], references: [id])
  company     Company?          @relation(fields: [companyId], references: [id])
  owner       User?             @relation("OpportunityOwner", fields: [ownerId], references: [id])

  @@index([leadId])
  @@index([stage])
  @@index([ownerId])
  @@map("opportunities")
}

model LeadScore {
  id         String   @id @default(uuid())
  leadId     String
  score      Int      @default(0)
  factor     String
  reason     String?
  aiScore    Float?
  confidence Float?
  createdAt  DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_scores")
}

model ScoringRule {
  id        String   @id @default(uuid())
  name      String
  field     String
  operator  String
  value     String
  points    Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("scoring_rules")
}

model Sequence {
  id          String   @id @default(uuid())
  name        String
  description String?
  ownerId     String?
  isActive    Boolean  @default(true)
  targets     Json?
  metrics     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User?         @relation(fields: [ownerId], references: [id])
  steps SequenceStep[]

  @@map("sequences")
}

model SequenceStep {
  id         String          @id @default(uuid())
  sequenceId String
  order      Int
  type       SequenceStepType
  subject    String?
  content    String?
  delayDays  Int             @default(0)
  condition  Json?
  metadata   Json?
  createdAt  DateTime        @default(now())

  sequence Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
  @@map("sequence_steps")
}

model Campaign {
  id             String   @id @default(uuid())
  name           String
  description    String?
  source         LeadSource
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  budget         Decimal  @default(0)
  spent          Decimal  @default(0)
  leadsGenerated Int      @default(0)
  conversions    Int      @default(0)
  startDate      DateTime?
  endDate        DateTime?
  isActive       Boolean  @default(true)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("campaigns")
}

model Workflow {
  id          String              @id @default(uuid())
  name        String
  description String?
  isActive    Boolean             @default(true)
  triggerType WorkflowTriggerType
  triggerConfig Json?
  conditions  Json?
  actions     Json?
  runCount    Int                 @default(0)
  lastRunAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@map("workflows")
}

model Notification {
  id        String             @id @default(uuid())
  userId    String
  title     String
  message   String?
  channel   NotificationChannel @default(IN_APP)
  isRead    Boolean            @default(false)
  link      String?
  metadata  Json?
  createdAt DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model Integration {
  id         String              @id @default(uuid())
  provider   IntegrationProvider
  name       String
  isActive   Boolean             @default(true)
  config     Json?
  lastSyncAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@map("integrations")
}

model ChatbotSession {
  id         String   @id @default(uuid())
  leadId     String
  visitorId  String?
  messages   Json?
  intent     String?
  qualified  Boolean  @default(false)
  bookedMeeting Boolean @default(false)
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("chatbot_sessions")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  changes   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}
